#-------------------------------------------------------------------------------
# wxNotepad++ -- build output, CMake artifacts, IDE / OS cruft
#-------------------------------------------------------------------------------

#-- CMake / wxWidgets
# Out-of-source build dirs (build/, build-*/, out/) hold ALL CMake output and the
# wxWidgets sources/libs fetched via FetchContent (build*/_deps/, tens of thousands
# of files) -- never commit these.
/build*/
/out/
CMakeUserPresets.json
CMakeSettings.json
# In-source CMake artifacts, in case anyone configures inside the source tree:
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
compile_commands.json
_deps/

#-- Visual Studio / VS Code
.vs/
.vscode/
*.suo
*.user
*.sln.docstates
*.opendb
*.VC.db
ipch/
*.aps
*.ncb
*.sdf
*.opensdf

#-- Compiler / linker artifacts
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Oo]bj/
*.obj
*.o
*.pdb
*.ilk
*.exe
*.lib
*.exp
*.log
*.tmp

#-- OS / editor
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.DS_Store
*~
*.swp
