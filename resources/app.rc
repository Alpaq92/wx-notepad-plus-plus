// Embeds wxnote.ico as the .exe's Win32 icon resource, so Windows Explorer /
// the taskbar / shortcuts show it for the file itself (separate from the SVG-based
// icon app_icon_svg.h sets on the running wxTopLevelWindow).
IDI_APPICON ICON "wxnote.ico"

// File/product version shown on the exe's Explorer Properties > Details tab. Keep in sync with
// the project() version in CMakeLists.txt on every release (the NSIS script reads its version
// from CMakeLists.txt directly; this block is only the exe's own metadata).
1 VERSIONINFO
FILEVERSION     0,6,2,0
PRODUCTVERSION  0,6,2,0
FILEFLAGSMASK   0x3fL
FILEFLAGS       0x0L
FILEOS          0x40004L
FILETYPE        0x1L
FILESUBTYPE     0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "wxNote Project"
            VALUE "FileDescription",  "wxNote - experimental cross-platform text editor"
            VALUE "FileVersion",      "0.6.2.0"
            VALUE "InternalName",     "wxnote"
            VALUE "OriginalFilename", "wxnote.exe"
            VALUE "ProductName",      "wxNote"
            VALUE "ProductVersion",   "0.6.2.0"
            VALUE "LegalCopyright",   "GPL v3 - see LICENSE"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
