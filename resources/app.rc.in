// Generated by CMake from resources/app.rc.in via configure_file() - do NOT edit the generated
// build/app.rc; edit this template. The version fields are substituted from the single source of
// truth, project(wxNote VERSION ...) in CMakeLists.txt, so the exe's Explorer Properties > Details
// version can never drift from the release version again (it silently shipped 0.7.0 for the 0.8.0
// release back when this block was hand-maintained).

// Embeds wxnote.ico as the .exe's Win32 icon resource, so Windows Explorer / the taskbar /
// shortcuts show it for the file itself (separate from the SVG-based icon app_icon_svg.h sets on
// the running wxTopLevelWindow). Absolute path because the generated .rc lives in the build dir.
IDI_APPICON ICON "@CMAKE_SOURCE_DIR@/resources/wxnote.ico"

1 VERSIONINFO
FILEVERSION     @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
PRODUCTVERSION  @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
FILEFLAGSMASK   0x3fL
FILEFLAGS       0x0L
FILEOS          0x40004L
FILETYPE        0x1L
FILESUBTYPE     0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "wxNote Project"
            VALUE "FileDescription",  "wxNote - experimental cross-platform text editor"
            VALUE "FileVersion",      "@PROJECT_VERSION@.0"
            VALUE "InternalName",     "wxnote"
            VALUE "OriginalFilename", "wxnote.exe"
            VALUE "ProductName",      "wxNote"
            VALUE "ProductVersion",   "@PROJECT_VERSION@.0"
            VALUE "LegalCopyright",   "Apache-2.0 - see LICENSE"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
