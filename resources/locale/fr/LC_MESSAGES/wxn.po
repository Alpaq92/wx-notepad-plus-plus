msgid "Usage: wxnote [options] [files...]\n\nFiles:\n  file                     open in a tab\n  folder                   open as a workspace\n  file:line[:col]          open at a position\n  +N, +N,col               open the last file at line N (and column)\n  +/text                   put the caret on the first match of 'text'\n  -                        read piped input into a new untitled buffer\n\nOptions:\n  -g, --goto <line[,col]>  go to this line (and column) in the last file opened\n  -e, --encoding <name>    force encoding: ansi|utf8|utf8bom|utf16le|utf16be\n  -R, -M, --read-only      open the given file(s) read-only\n  -o, -O, --split          open the given file(s) in a split view\n  -n, --new-instance       always open a new window\n  -r, --reuse-instance     reuse an already-running window\n  -w, --wait               wait for the file to be closed before returning\n  --safe                   start without loading any plugins\n  --clean                  like --safe, plus skip session and recovery restore\n  --locale <lang>          UI language for this run (e.g. pl, de, ja)\n  -v, --version            print the version and exit\n  -h, --help               show this help message"
msgstr "Utilisation : wxnote [options] [fichiers...]\n\nFichiers :\n  file                     ouvrir dans un onglet\n  folder                   ouvrir comme espace de travail\n  file:line[:col]          ouvrir à une position\n  +N, +N,col               ouvrir le dernier fichier à la ligne N (et la colonne)\n  +/text                   placer le curseur sur la première occurrence de 'text'\n  -                        lire l'entrée du tube dans un nouveau tampon sans titre\n\nOptions :\n  -g, --goto <line[,col]>  aller à cette ligne (et colonne) dans le dernier fichier ouvert\n  -e, --encoding <name>    forcer l'encodage : ansi|utf8|utf8bom|utf16le|utf16be\n  -R, -M, --read-only      ouvrir le(s) fichier(s) indiqué(s) en lecture seule\n  -o, -O, --split          ouvrir le(s) fichier(s) indiqué(s) en vue partagée\n  -n, --new-instance       toujours ouvrir une nouvelle fenêtre\n  -r, --reuse-instance     réutiliser une fenêtre déjà ouverte\n  -w, --wait               attendre la fermeture du fichier avant de rendre la main\n  --safe                   démarrer sans charger de plugins\n  --clean                  comme --safe, en ignorant aussi la restauration de session et de récupération\n  --locale <lang>          langue de l'interface pour cette exécution (p. ex. pl, de, ja)\n  -v, --version            afficher la version et quitter\n  -h, --help               afficher cette aide"

